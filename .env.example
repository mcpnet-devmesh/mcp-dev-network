# PostgreSQL (Railway te lo da automáticamente si vinculas el servicio PG)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Cifrado AES-256 — genera con: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# OAuth 2.1 — una de las dos:
OAUTH_ISSUER=https://tu-auth-provider.com
OAUTH_PUBLIC_KEY=
# o bien:
# OAUTH_JWKS_URL=https://tu-auth-provider.com/.well-known/jwks.json

# PostgreSQL (Supabase pooler)
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASS@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# AES-256 key (generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())")
ENCRYPTION_KEY=

# OAuth - JWT RS256
OAUTH_ISSUER=https://your-project.supabase.co
OAUTH_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...-----END PUBLIC KEY-----
OAUTH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...-----END PRIVATE KEY-----

# Optional
PORT=8000
